{
  "name": "lineage2-api",
  "version": "0.9.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "typecheck:scripts": "tsc --noEmit -p tsconfig.scripts.json",
    "build:data": "tsx scripts/build-data.ts",
