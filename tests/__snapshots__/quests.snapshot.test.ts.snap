exports[`quest 211 (Trial of the Challenger) DTO matches snapshot 1`] = `
{
  "classRestrictions": [],
  "clientJournalEntries": [
    {
      "completionNpc": null,
      "description": "Kash says that anyone who wants to get the mark of challenger should enter the cave behind the Undine Waterfall in the northern part of the Neutral Zone, destroy Shyslassys and retrieve an old parchment.\\n\\n\\nMonster to Hunt - The Shyslassys",
      "stepIndex": 1,
      "title": "Cave of the Shyslassys",
    },
    {
      "completionNpc": {
        "id": 30644,
        "name": "Kash",
      },
      "description": "You've defeated Shyslassys and retrieved the parchment. Take it to Kash.\\n",
      "stepIndex": 2,
      "title": "Return to Kash",
    },
    {
      "completionNpc": {
        "id": 30645,
        "name": "Martien",
      },
      "description": "Kash tells you to get the mark of challenger from Martien in Giran Castle Town.\\n",
      "stepIndex": 3,
      "title": "In search of Martien",
    },
    {
      "completionNpc": null,
      "description": "Martien says that he will give you the mark of challenger if you defeat an evil spirit known as Gorr that haunts the area around Floran Village.\\n\\n\\n",
      "stepIndex": 4,
      "title": "Defeat Gorr",
    },
    {
      "completionNpc": {
        "id": 30645,
        "name": "Martien",
      },
      "description": "You defeated Gorr and taken the mark of the watcher's eye. Now return to Martien for the mark of challenger.\\n",
      "stepIndex": 5,
      "title": "Return to Martien",
    },
    {
      "completionNpc": null,
      "description": "Gorr's defeat has not made the people of Floran Village any safer. They're now threatened by another evil creature. Find and destroy Baraham in the caves near Gorr's lair.\\n\\nMonster to Hunt -  Baraham\\n",
      "stepIndex": 6,
      "title": "Defeat Baraham",
    },
    {
      "completionNpc": null,
      "description": "You've defeated Baraham. Who is this mysterious stranger? \\n",
      "stepIndex": 7,
      "title": "Raldo",
    },
    {
      "completionNpc": null,
      "description": "Champion Raldo warns of an evil that will be resurrected unless a magic force field remains protected. Speak with Filaur of the Gray Pillar in the Dwarven Village and ask him where the last magic force field was known to exist.\\n",
      "stepIndex": 8,
      "title": "The Final Magic Force Field",
    },
    {
      "completionNpc": null,
      "description": "There's an evil energy in the deepest part of the Mithril Mines and the magic force field is threatened. Why is there earth wyrm blood everywhere? Could that Succubus Queen be their leader? \\n\\nMonster to Hunt - Succubus Queen\\n",
      "stepIndex": 9,
      "title": "Protect the Magic Force Field",
    },
    {
      "completionNpc": null,
      "description": "At the death of the Succubus Queen, Raldo reappears. Speak with him.\\n",
      "stepIndex": 10,
      "title": "Raldo's Reappearance",
    },
  ],
  "description": "Many Warriors seek the challenger's mark as proof of their valor. A conspiracy of darkness surrounds the mark.",
