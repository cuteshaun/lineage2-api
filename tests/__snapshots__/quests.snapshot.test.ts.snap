exports[`quest 1 (Letters of Love) DTO matches snapshot 1`] = `
{
  "classRestrictions": [],
  "clientJournalEntries": [
    {
      "completionNpc": {
        "id": 30006,
        "name": "Roxxy",
      },
      "description": "Darin of Talking Island Village has fallen in love with Gatekeeper Roxxy. He is too shy to express his feelings and asks you to deliver his love letter to her.\\n",
      "stepIndex": 1,
      "title": "Delivery of Love Letters",
    },
    {
      "completionNpc": {
        "id": 30048,
        "name": "Darin",
      },
      "description": "Roxxy reads Darin's letter and tells you that she admires him as well. She asks you to deliver her kerchief to him. Take Roxxy's kerchief to Darin in the village square.\\n",
      "stepIndex": 2,
      "title": "Roxxy's Kerchief",
    },
    {
      "completionNpc": {
        "id": 30033,
        "name": "Baulro",
      },
      "description": "Darin is overjoyed to learn that Roxxy returns his admiration, and says he wants to ask her for a date. He asks you to go and get a love potion promised to him by Magister Baulro at the temple.\\n",
      "stepIndex": 3,
      "title": "Baulro's Magic Potion",
    },
    {
      "completionNpc": {
        "id": 30048,
        "name": "Darin",
      },
      "description": "Magister Baulro admits that he deceived Darin about the potion in order to bolster his courage. He gives you a medicine bottle filled with tap water. Take it to Darin in the village square.\\n",
      "stepIndex": 4,
      "title": "Water that Brings Out Courage",
    },
  ],
  "description": "Darin, a young man on Talking Island, carries a torch for Gatekeeper Roxxy, who doesn't return his affections. Darin is not so easily dissuaded, however.",
